{
  "compilerOptions": {
    "target": "ES2020",
    "useDefineForClassFields": true,
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "skipLibCheck": true,

    /* Ushbu ikkita qatorni qo'shishingiz shart: */
    "baseUrl": ".",
    "paths": {
      "@/*": ["./src/*"]
    },

    /* Qolgan kodlar o'zgarishsiz qolaveradi... */
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "jsx": "react-jsx"
  },
  "include": ["src"]
}
